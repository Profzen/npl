    "INSERT": ("INSERT", "INSERTION", "AJOUT", "AJOUTE", "AJOUTER", "CREE LIGNE", "CREATION LIGNE"),
    "UPDATE": ("UPDATE", "MODIFICATION", "MODIFIE", "MODIFIER", "MIS A JOUR", "MISE A JOUR", "CHANGE"),
