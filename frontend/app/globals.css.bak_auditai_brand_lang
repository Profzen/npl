@import 'tailwindcss';
@import 'tw-animate-css';

@custom-variant dark (&:is(.dark *));

/*
  ASKSMART THEME SYSTEM
  Thème actif recommandé : Bleu ardoise

  Pour changer rapidement de thème, modifier uniquement frontend/app/layout.tsx :
  <html lang="fr" data-theme="slate">     -> Bleu ardoise
  <html lang="fr" data-theme="graphite">  -> Gris graphite
*/

:root,
html[data-theme='slate'] {
  /* ==============================
     THÈME 1 — BLEU ARDOISE, ACTIF
     ============================== */
  --background: #edf4fa;
  --foreground: #142033;
  --card: #f8fbff;
  --card-foreground: #142033;
  --popover: #f8fbff;
  --popover-foreground: #142033;

  /* SMART 2D red for CTAs and important accents */
  --primary: #d71920;
  --primary-foreground: #ffffff;
  --secondary: #e7eef7;
  --secondary-foreground: #142033;
  --muted: #dfe8f2;
  --muted-foreground: #5b6b7f;
  --accent: #dce9f7;
  --accent-foreground: #142033;
  --destructive: #d71920;
  --destructive-foreground: #ffffff;
  --border: #cfdae7;
  --input: #d6e1ed;
  --ring: #d71920;

  /* Status colors */
  --status-success: #19a262;
  --status-warning: #f59e0b;
  --status-error: #d71920;

  /* Category colors */
  --category-users: #d71920;
  --category-objects: #16263a;
  --category-actions: #d71920;

  /* Charts */
  --chart-1: #d71920;
  --chart-2: #1f5f8f;
  --chart-3: #16263a;
  --chart-4: #f59e0b;
  --chart-5: #19a262;

  --radius: 0.75rem;

  /* Sidebar */
  --sidebar: #13243a;
  --sidebar-foreground: #f5f9ff;
  --sidebar-primary: #d71920;
  --sidebar-primary-foreground: #ffffff;
  --sidebar-accent: #213852;
  --sidebar-accent-foreground: #ffffff;
  --sidebar-border: rgba(226, 238, 249, 0.18);
  --sidebar-ring: #d71920;

  /* Custom visual polish */
  --app-bg-solid: #edf4fa;
  --app-bg:
    radial-gradient(circle at 18% 8%, rgba(199, 220, 241, 0.65), transparent 30%),
    radial-gradient(circle at 80% 0%, rgba(232, 239, 248, 0.9), transparent 28%),
    linear-gradient(135deg, #f3f8fd 0%, #e7f0f9 100%);
  --card-shadow: 0 14px 34px rgba(15, 37, 64, 0.10), 0 2px 8px rgba(15, 37, 64, 0.05);
  --card-shadow-soft: 0 8px 22px rgba(15, 37, 64, 0.08), 0 1px 5px rgba(15, 37, 64, 0.04);
  --sidebar-shadow: 8px 0 28px rgba(8, 24, 44, 0.18);
}

html[data-theme='graphite'] {
  /* ================================
     THÈME 2 — GRIS GRAPHITE, OPTION
     Inactif tant que data-theme="graphite"
     n'est pas utilisé dans app/layout.tsx.
     ================================ */
  --background: #f3f5f7;
  --foreground: #111827;
  --card: #ffffff;
  --card-foreground: #111827;
  --popover: #ffffff;
  --popover-foreground: #111827;

  --primary: #d71920;
  --primary-foreground: #ffffff;
  --secondary: #eceff3;
  --secondary-foreground: #111827;
  --muted: #e5e9ef;
  --muted-foreground: #5b6470;
  --accent: #e8edf3;
  --accent-foreground: #111827;
  --destructive: #d71920;
  --destructive-foreground: #ffffff;
  --border: #d5dbe3;
  --input: #d9dfe7;
  --ring: #d71920;

  --status-success: #16a34a;
  --status-warning: #f59e0b;
  --status-error: #d71920;

  --category-users: #d71920;
  --category-objects: #252d37;
  --category-actions: #d71920;

  --chart-1: #d71920;
  --chart-2: #475569;
  --chart-3: #111827;
  --chart-4: #f59e0b;
  --chart-5: #16a34a;

  --radius: 0.75rem;

  --sidebar: #1e252e;
  --sidebar-foreground: #f8fafc;
  --sidebar-primary: #d71920;
  --sidebar-primary-foreground: #ffffff;
  --sidebar-accent: #2a333d;
  --sidebar-accent-foreground: #ffffff;
  --sidebar-border: rgba(248, 250, 252, 0.16);
  --sidebar-ring: #d71920;

  --app-bg-solid: #f3f5f7;
  --app-bg:
    radial-gradient(circle at 18% 8%, rgba(226, 232, 240, 0.72), transparent 30%),
    linear-gradient(135deg, #f8fafc 0%, #eef2f6 100%);
  --card-shadow: 0 14px 34px rgba(17, 24, 39, 0.09), 0 2px 8px rgba(17, 24, 39, 0.05);
  --card-shadow-soft: 0 8px 22px rgba(17, 24, 39, 0.07), 0 1px 5px rgba(17, 24, 39, 0.04);
  --sidebar-shadow: 8px 0 28px rgba(17, 24, 39, 0.22);
}

@theme inline {
  --font-sans: 'Geist', 'Geist Fallback';
  --font-mono: 'Geist Mono', 'Geist Mono Fallback';
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);
  --color-status-success: var(--status-success);
  --color-status-warning: var(--status-warning);
  --color-status-error: var(--status-error);
  --color-category-users: var(--category-users);
  --color-category-objects: var(--category-objects);
  --color-category-actions: var(--category-actions);
  --color-chart-1: var(--chart-1);
  --color-chart-2: var(--chart-2);
  --color-chart-3: var(--chart-3);
  --color-chart-4: var(--chart-4);
  --color-chart-5: var(--chart-5);
  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 4px);
  --color-sidebar: var(--sidebar);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-ring: var(--sidebar-ring);
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }

  html {
    background: var(--app-bg-solid);
  }

  body {
    @apply text-foreground;
    min-height: 100vh;
    background: var(--app-bg);
  }

  ::selection {
    color: var(--primary-foreground);
    background: var(--primary);
  }

  [data-slot='sidebar-wrapper'],
  [data-slot='sidebar-inset'] {
    background: var(--app-bg);
  }

  [data-slot='sidebar-inner'] {
    box-shadow: var(--sidebar-shadow);
  }

  [data-slot='card'] {
    box-shadow: var(--card-shadow-soft);
  }

  input,
  textarea,
  select {
    background-color: color-mix(in srgb, var(--card) 92%, white 8%);
  }
}
